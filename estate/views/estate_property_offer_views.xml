<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estate_property_offer_view_list" model="ir.ui.view">
        <field name="name">estate.property.offer.list</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="price"/>
                <field name="property_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="estate_property_offer_view_form" model="ir.ui.view">
        <field name="name">estate.property.offer.form</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept" type="object" string="Accept" icon="fa-check" invisible="status == 'accepted'"/>
                    <button name="action_refuse" type="object" string="Refuse" icon="fa-times" invisible="status == 'refused'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="price"/>
                        <field name="property_id"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_offer_action" model="ir.actions.act_window">
        <field name="name">Property Offers</field>
        <field name="res_model">estate.property.offer</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="estate_menu_property_offer"
              name="Property Offers"
              parent="estate_menu_settings"
              action="estate_property_offer_action">
    </menuitem>

</odoo>
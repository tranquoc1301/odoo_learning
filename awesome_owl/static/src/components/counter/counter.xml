<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="awesome_owl.Counter">
        <div class="counter">
            <div>
                <div class="counter-label">Counter</div>
                <div class="counter-value"><t t-esc="state.value"/></div>
            </div>
            <button class="btn-increment" t-on-click="increment">+ Increment</button>
        </div>
    </t>
</templates>

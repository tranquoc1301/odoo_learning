<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_shopify_config_list" model="ir.ui.view">
        <field name="name">shopify.config.list</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <list string="Shopify Stores"
                  decoration-success="active"
                  decoration-muted="not active">
                <field name="name"/>
                <field name="shop_url"/>
                <field name="warehouse_id"/>
                <field name="last_sync"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_shopify_config_form" model="ir.ui.view">
        <field name="name">shopify.config.form</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <form string="Shopify Store Configuration">
                <header>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object"
                            icon="fa-plug"
                            title="Test the connection to your Shopify store"
                            class="oe_highlight"/>
                    <button name="sync_all"
                            string="Sync All"
                            type="object"
                            icon="fa-refresh"
                            title="Sync all products, orders and inventory from Shopify"/>
                </header>

                <sheet>
                    <group>
                        <group string="Connection Details">
                            <field name="name"/>
                            <field name="shop_url"/>
                            <field name="api_access_token" password="True"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Warehouse Settings">
                            <field name="warehouse_id"/>
                            <field name="last_sync"/>
                        </group>
                    </group>

                    <notebook>
                        <page name="sync_logs" string="Sync Logs">
                            <field name="sync_log_ids" nolabel="1">
                                <list default_order="run_at desc"
                                      limit="20"
                                      create="false" edit="false" delete="false"
                                      decoration-success="status == 'success'"
                                      decoration-warning="status == 'partial'"
                                      decoration-danger="status == 'failed'">
                                    <field name="run_at" string="Time" optional="show"/>
                                    <field name="sync_type" string="Type" optional="show"/>
                                    <field name="status"
                                           string="Status"
                                           widget="badge"
                                           decoration-success="status == 'success'"
                                           decoration-warning="status == 'partial'"
                                           decoration-danger="status == 'failed'"
                                           optional="show"/>
                                    <field name="shopify_id"
                                           string="Shopify ID"
                                           optional="hide"/>
                                    <field name="external_ref"
                                           string="Reference"
                                           optional="hide"/>
                                    <field name="message" string="Message" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_shopify_config_search" model="ir.ui.view">
        <field name="name">shopify.config.search</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <search string="Search Shopify Stores">
                <field name="name"/>
                <field name="shop_url"/>
                <filter string="Active"
                        name="filter_active"
                        domain="[('active', '=', True)]"/>
                <filter string="Inactive"
                        name="filter_inactive"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_shopify_config" model="ir.actions.act_window">
        <field name="name">Shopify Stores</field>
        <field name="res_model">shopify.config</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">No Shopify store configured</p>
            <p>Add a Shopify store to start syncing products and orders.</p>
        </field>
    </record>

    <!-- Menu Item under Sales app -->
    <menuitem id="menu_shopify_config"
              name="Shopify Stores"
              action="action_shopify_config"
              parent="sale.sale_menu_root"
              sequence="90"/>

</odoo>